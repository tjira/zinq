{
    "zinq" : [
        {
            "name" : "quantum_dynamics",
            "options" : {
                "grid" : {
                    "limits" : [[-8, 8]],
                    "points" : 64
                },
                "initial_conditions" : {
                    "mass" : 1,
                    "momentum" : [0],
                    "position" : [1],
                    "state" : 0,
                    "gamma" : [2]
                },
                "log_intervals" : {
                    "iteration" : 1000
                },
                "potential" : {
                    "harmonic" : {
                        "k" : [1]
                    }
                },
                "write" : {
                    "autocorrelation_function" : "ACF.mat",
                    "spectrum" : "SPECTRUM.mat"
                },
                "iterations" : 10000,
                "time_step" : 0.01
            }
        }
    ],
    "command" : "plot ACF.mat SPECTRUM.mat --figsize 3 8 --subplots 121 121 122 --title 'Autocorrelation Function' 'Spectrum' --xlabel '$t$ (a.u)' '$E$ (a.u.)' --xlim nan nan 0 5 --output ACF_SPECTRUM.pdf"
}
