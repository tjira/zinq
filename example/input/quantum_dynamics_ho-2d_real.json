{
    "zinq" : [
        {
            "quantum_dynamics" : {
                "grid" : {
                    "bounds" : [[-8, 8], [-8, 8]],
                    "npoint" : 128
                },
                "initial_conditions" : {
                    "position" : [1, 1],
                    "momentum" : [0, 0],
                    "gamma" : [2, 2],
                    "state" : 0
                },
                "potential" : {
                    "harmonic" : {
                        "k" : [1, 1]
                    }
                },
                "spectrum" : {
                    "padding" : 100000,
                    "write" : {
                        "spectrum" : "SPECTRUM.mat"
                    }
                },
                "write" : {
                    "acf" : "ACF.mat"
                },
                "mass" : 1,
                "iterations" : 10000,
                "time_step" : 0.1,
                "log_interval" : 2000
            }
        }
    ]
}
